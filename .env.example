# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase Database (Direct Connection)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# REZ API Configuration
REZ_API_URL=https://api.rez.com/v2
REZ_API_KEY=your-rez-api-key
REZ_CLIENT_ID=your-rez-client-id
REZ_CLIENT_SECRET=your-rez-client-secret
REZ_WEBHOOK_SECRET=your-rez-webhook-secret

# REZ OAuth2 Partner Credentials (NextaBiZ as Partner App)
# These enable SSO via REZ Auth Service (partner key: "nextabizz")
# Generate client secret with: openssl rand -base64 64
NEXT_PUBLIC_NEXTABIZZ_CLIENT_ID=nextabizz
REZ_OAUTH_CLIENT_SECRET=change-me-generate-with-openssl-rand-base64-64
# REZ Auth Service URL (used by OAuth2 login flow)
REZ_AUTH_SERVICE_URL=https://rez-auth-service.onrender.com
# Merchant Service — for looking up merchant by REZ user ID (OAuth2 linkage)
REZ_MERCHANT_SERVICE_URL=http://localhost:4005
# Internal service token for calling merchant service internal APIs (from rez-merchant-service INTERNAL_SERVICE_TOKEN)
REZ_INTERNAL_KEY=your-rez-internal-service-token

# Resend (Email)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Webhook Endpoints
WEBHOOK_REZ_MERCHANT_SECRET=your-rez-merchant-webhook-secret
WEBHOOK_RESTOPAPA_SECRET=your-restopapa-webhook-secret
WEBHOOK_HOTEL_PMS_SECRET=your-hotel-pms-webhook-secret

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPLIER_PORTAL_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key
JWT_SECRET=your-jwt-secret

# Stripe (Payment Settlement)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# Feature Flags
ENABLE_REORDER_ENGINE=true
ENABLE_SCORING_ENGINE=true
ENABLE_PAYMENT_SETTLEMENT=true

# ReZ Mind Intent Capture (AI / Recommendation Engine)
NEXT_PUBLIC_INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com

# Rate Limiting
UPSTASH_REDIS_URL=redis://default:your-password@your-redis-url:6379
UPSTASH_REDIS_TOKEN=your-upstash-token

# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Vercel (Deployment)
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id
