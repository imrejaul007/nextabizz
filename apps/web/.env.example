# ===========================================
# NEXTABIZZ PRODUCTION ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control

# ===========================================
# SUPABASE (Required)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===========================================
# APPLICATION URLS (Required for CORS)
# ===========================================
NEXT_PUBLIC_APP_URL=https://app.nextabizz.com
NEXT_PUBLIC_API_URL=https://api.nextabizz.com
NEXT_PUBLIC_WEB_URL=https://nextabizz.com
NEXT_PUBLIC_REZ_APP_URL=https://rezapp.com

# ===========================================
# AUTHENTICATION (Critical for Security)
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-min-32-characters-long
JWT_EXPIRY=3600

# ===========================================
# WEBHOOK SECRETS (For Verifying Incoming Webhooks)
# ===========================================
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET_RESTOPAPA=your-restopapa-webhook-secret
WEBHOOK_SECRET_REZ_MERCHANT=your-rez-merchant-webhook-secret
WEBHOOK_SECRET_HOTEL_PMS=your-hotel-pms-webhook-secret

# ===========================================
# REZ INTEGRATION (For ReZ Platform Sync)
# ===========================================
REZ_API_GATEWAY_URL=https://api.rez.money

# Merchant Service — for looking up merchant by REZ user ID (OAuth2 linkage)
REZ_MERCHANT_SERVICE_URL=http://localhost:4005

# Internal service token for calling merchant service internal APIs
REZ_INTERNAL_KEY=your-rez-internal-service-token

# ===========================================
# REZ OAUTH2 PARTNER SSO (NextaBiZ as Partner App)
# ===========================================
# Auth service URL — used by client-side for OAuth initiation (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_REZ_AUTH_URL=https://auth.rez.money
# Client ID — registered as partner key "nextabizz" in REZ Auth Service
NEXT_PUBLIC_NEXTABIZZ_CLIENT_ID=nextabizz
# Redirect URI — must match PARTNER_NEXTABIZZ_REDIRECT_URI registered in REZ Auth Service
# Dev: http://localhost:3000/api/auth/callback
# Prod: https://app.nextabizz.com/api/auth/callback
NEXT_PUBLIC_NEXTABIZZ_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Client secret — MUST match PARTNER_NEXTABIZZ_CLIENT_SECRET in REZ Auth Service
# Generate with: openssl rand -base64 64
REZ_OAUTH_CLIENT_SECRET=change-me-generate-with-openssl-rand-base64-64

# ===========================================
# PAYMENT GATEWAY - RAZORPAY (Production)
# ===========================================
RAZORPAY_KEY_ID=rzp_live_your-key-id
RAZORPAY_KEY_SECRET=rzp_live_your-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ===========================================
# ERROR TRACKING - SENTRY (Optional but Recommended)
# ===========================================
# Get from: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ===========================================
# ENVIRONMENT
# ===========================================
NODE_ENV=production
NEXT_PUBLIC_ENVIRONMENT=production

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info

# ===========================================
# REZ MIND INTENT CAPTURE (AI / Recommendation Engine)
# ===========================================
NEXT_PUBLIC_INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com
# Internal service key — must match INTENT_CAPTURE_URL server config
INTERNAL_SERVICE_TOKEN=your-internal-service-token

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ===========================================
# CACHE (For Vercel KV or Upstash Redis)
# ===========================================
KV_URL=redis://your-redis-url
KV_REST_API_URL=https://your-kv-rest-api-url
KV_REST_API_TOKEN=your-kv-rest-api-token
KV_REST_API_READ_ONLY_TOKEN=your-kv-read-only-token
